{
  "name": "warehouse-frontend",
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "deploy": "vite build && npx wrangler pages deploy dist --branch=main",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "type-check": "tsgo --noEmit --incremental",
    "generate-api:live": "openapi --input http://127.0.0.1:8788/openapi.json --output src/generated-api --name WarehouseClient --useOptions --useUnionTypes",
    "generate-api": "cd ../warehouse-backend && npm run openapi:export && cd ../warehouse-frontend && openapi --input ../warehouse-backend/openapi.json --output src/generated-api --name WarehouseClient --useOptions --useUnionTypes",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.28.0",
    "axios": "^1.6.0",
    "html5-qrcode": "^2.3.8",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.22.0",
    "tesseract.js": "^7.0.0",
    "zustand": "^4.4.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/node": "^25.5.2",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@typescript/native-preview": "latest",
    "@vitejs/plugin-react": "^4.2.0",
    "openapi-typescript-codegen": "^0.29.0",
    "oxfmt": "latest",
    "oxlint": "latest",
    "playwright": "^1.40.0",
    "rollup-plugin-visualizer": "^5.10.0",
    "typescript": "^5.3.0",
    "vite": "^5.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
